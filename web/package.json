{
  "name": "dungeon-debt",
  "version": "0.1.0",
  "private": true,
  "description": "Dungeon Debt desktop package",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "test:headless": "node src/test/headless.js && node src/test/combat.js && node src/test/run.js",
    "pack:win": "electron-builder --win dir",
    "dist:win": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.dungeondebt.game",
    "productName": "DungeonDebt",
    "asar": true,
    "files": [
      "index.html",
      "src/**/*",
      "styles/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["dir", "nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "DungeonDebt"
    }
  },
  "devDependencies": {
    "electron": "^42.1.0",
    "electron-builder": "^26.10.0"
  }
}
